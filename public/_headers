# Cross-origin isolation, scoped to the video room ONLY (spec §5).
# Enables SharedArrayBuffer, which the Zoom Video SDK needs to RENDER VIDEO in
# Safari (audio works without it; video does not).
#
# Must be `require-corp`, NOT `credentialless`: Safari does not support
# `credentialless`, so it would never become cross-origin isolated → black video.
# Zoom's SDK assets send the matching CORP/CORS headers, and the session page
# loads no other cross-origin resources, so require-corp is safe here.
# Scoped to /session/* so the rest of the app (Supabase/ElevenLabs audio) is
# untouched.
#
# NOTE: isolation applies to a FRESH document load of /session/*. Open the session
# link directly (hard navigation) — an SPA client-side nav into it won't isolate.
/session/*
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Embedder-Policy: require-corp
